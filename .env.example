# Copy to .env.local (DO NOT COMMIT) before running `npm run local-action`

# ─── Required ───────────────────────────────────────────────────────────────

# Real GITHUB_TOKEN with write:issues access to your sandbox repo
GITHUB_TOKEN=ghp_replace_me

# ─── GitHub Context (required by @actions/github) ──────────────────────────

GITHUB_EVENT_NAME=issues
GITHUB_REPOSITORY=your-username/signal-oss-sandbox
GITHUB_ACTOR=your-username

# Fixture event payload for local testing
GITHUB_EVENT_PATH=./fixtures/event.json

# ─── Action Inputs (all optional — defaults shown) ─────────────────────────

# INPUT_DRY-RUN=false
# INPUT_ENABLE-COMMENTS=true
# INPUT_ENABLE-LABELS=true
# INPUT_LABEL-NAME=needs-info
# INPUT_MODEL=
# INPUT_GRAY-ZONE-LOW=4
# INPUT_GRAY-ZONE-HIGH=6
# INPUT_MAX-BODY-BYTES=10000
